# ==============================================================================
# NovaBite Sales Insights - Consolidated Environment Variables Template
# ==============================================================================

# --- Backend Configuration (FastAPI) ---
# Your Groq API key (Required for Chat feature)
# Obtain a free key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# SQLite Database connection URL
# Defaults to a local file in the backend directory
DATABASE_URL=sqlite:///./sales_insights.db

# Port number for the FastAPI backend server (Defaults to 8000)
PORT=8000


# --- Frontend Configuration (React/Vite) ---
# API base url for the React application to connect to the FastAPI backend
VITE_API_BASE_URL=http://localhost:8000
